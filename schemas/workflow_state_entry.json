{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WorkflowStateEntry",
  "type": "object",
  "required": [
    "description",
    "id"
  ],
  "properties": {
    "description": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Z][A-Za-z0-9]*$"
    },
    "semantic": {
      "anyOf": [
        {
          "$ref": "#/definitions/WorkflowSemantic"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "definitions": {
    "WorkflowSemantic": {
      "type": "string",
      "enum": [
        "reviewing",
        "complete",
        "blocked",
        "failed"
      ]
    }
  }
}
