{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "definitions": {
    "EmbeddedWorkflowEntityRef": {
      "properties": {
        "id": {
          "pattern": "^[A-Z][A-Za-z0-9]*$",
          "type": "string"
        },
        "kind": {
          "enum": [
            "EmbeddedWorkflow"
          ],
          "type": "string"
        },
        "parent": {
          "$ref": "#/definitions/WorkflowParent"
        }
      },
      "required": [
        "id",
        "kind",
        "parent"
      ],
      "title": "EmbeddedWorkflowEntityRef",
      "type": "object"
    },
    "HookCall": {
      "additionalProperties": false,
      "description": "Usage-site reference to a hook with optional input bindings.",
      "properties": {
        "hook": {
          "$ref": "#/definitions/HookEntityRef"
        },
        "with": {
          "additionalProperties": {
            "type": "string"
          },
          "type": [
            "object",
            "null"
          ]
        }
      },
      "required": [
        "hook"
      ],
      "type": "object"
    },
    "HookEntityRef": {
      "properties": {
        "id": {
          "pattern": "^[a-z][a-z0-9-]*$",
          "type": "string"
        },
        "kind": {
          "enum": [
            "Hook"
          ],
          "type": "string"
        }
      },
      "required": [
        "id",
        "kind"
      ],
      "title": "HookEntityRef",
      "type": "object"
    },
    "Raci": {
      "additionalProperties": false,
      "description": "Accountability assignment for workflows and tasks.",
      "properties": {
        "accountable": {
          "$ref": "#/definitions/RoleEntityRef"
        },
        "consulted": {
          "items": {
            "$ref": "#/definitions/RoleEntityRef"
          },
          "type": [
            "array",
            "null"
          ]
        },
        "informed": {
          "items": {
            "$ref": "#/definitions/RoleEntityRef"
          },
          "type": [
            "array",
            "null"
          ]
        },
        "responsible": {
          "items": {
            "$ref": "#/definitions/RoleEntityRef"
          },
          "type": "array"
        }
      },
      "required": [
        "accountable",
        "responsible"
      ],
      "type": "object"
    },
    "RelayEntityRef": {
      "properties": {
        "id": {
          "pattern": "^[A-Z][A-Za-z0-9]*$",
          "type": "string"
        },
        "kind": {
          "enum": [
            "Relay"
          ],
          "type": "string"
        },
        "parent": {
          "$ref": "#/definitions/WorkflowParent"
        }
      },
      "required": [
        "id",
        "kind",
        "parent"
      ],
      "title": "RelayEntityRef",
      "type": "object"
    },
    "ReusableWorkflowEntityRef": {
      "properties": {
        "id": {
          "pattern": "^[A-Z][A-Za-z0-9]*$",
          "type": "string"
        },
        "kind": {
          "enum": [
            "ReusableWorkflow"
          ],
          "type": "string"
        }
      },
      "required": [
        "id",
        "kind"
      ],
      "title": "ReusableWorkflowEntityRef",
      "type": "object"
    },
    "RoleEntityRef": {
      "properties": {
        "id": {
          "pattern": "^[a-z][a-z0-9-]*$",
          "type": "string"
        },
        "kind": {
          "enum": [
            "Role"
          ],
          "type": "string"
        }
      },
      "required": [
        "id",
        "kind"
      ],
      "title": "RoleEntityRef",
      "type": "object"
    },
    "Step": {
      "description": "A step inside a workflow. Not an entity — no EntityRef, no derive(Entity).",
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "Task": {
              "additionalProperties": false,
              "properties": {
                "depends_on": {
                  "items": {
                    "type": "string"
                  },
                  "type": [
                    "array",
                    "null"
                  ]
                },
                "entity_ref": {
                  "$ref": "#/definitions/TaskEntityRef"
                }
              },
              "required": [
                "entity_ref"
              ],
              "type": "object"
            }
          },
          "required": [
            "Task"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "Relay": {
              "additionalProperties": false,
              "properties": {
                "depends_on": {
                  "items": {
                    "type": "string"
                  },
                  "type": [
                    "array",
                    "null"
                  ]
                },
                "entity_ref": {
                  "$ref": "#/definitions/RelayEntityRef"
                }
              },
              "required": [
                "entity_ref"
              ],
              "type": "object"
            }
          },
          "required": [
            "Relay"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "EmbeddedWorkflow": {
              "additionalProperties": false,
              "properties": {
                "depends_on": {
                  "items": {
                    "type": "string"
                  },
                  "type": [
                    "array",
                    "null"
                  ]
                },
                "entity_ref": {
                  "$ref": "#/definitions/EmbeddedWorkflowEntityRef"
                }
              },
              "required": [
                "entity_ref"
              ],
              "type": "object"
            }
          },
          "required": [
            "EmbeddedWorkflow"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "Review": {
              "additionalProperties": false,
              "properties": {
                "approver": {
                  "items": {
                    "$ref": "#/definitions/RoleEntityRef"
                  },
                  "type": "array"
                },
                "on_reject": {
                  "type": "string"
                }
              },
              "required": [
                "approver",
                "on_reject"
              ],
              "type": "object"
            }
          },
          "required": [
            "Review"
          ],
          "type": "object"
        }
      ]
    },
    "TaskEntityRef": {
      "properties": {
        "id": {
          "pattern": "^[A-Z][A-Za-z0-9]*$",
          "type": "string"
        },
        "kind": {
          "enum": [
            "Task"
          ],
          "type": "string"
        },
        "parent": {
          "$ref": "#/definitions/WorkflowParent"
        }
      },
      "required": [
        "id",
        "kind",
        "parent"
      ],
      "title": "TaskEntityRef",
      "type": "object"
    },
    "WorkflowEntityRef": {
      "properties": {
        "id": {
          "pattern": "^[A-Z][A-Za-z0-9]*$",
          "type": "string"
        },
        "kind": {
          "enum": [
            "Workflow"
          ],
          "type": "string"
        }
      },
      "required": [
        "id",
        "kind"
      ],
      "title": "WorkflowEntityRef",
      "type": "object"
    },
    "WorkflowParent": {
      "anyOf": [
        {
          "$ref": "#/definitions/WorkflowEntityRef"
        },
        {
          "$ref": "#/definitions/ReusableWorkflowEntityRef"
        },
        {
          "$ref": "#/definitions/EmbeddedWorkflowEntityRef"
        }
      ],
      "description": "Closed parent hierarchy for embedded entities in the workflow tree."
    },
    "WorkflowSemantic": {
      "enum": [
        "reviewing",
        "done",
        "blocked",
        "failed"
      ],
      "type": "string"
    },
    "WorkflowStateEntry": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "id": {
          "pattern": "^[A-Z][A-Za-z0-9]*$",
          "type": "string"
        },
        "semantic": {
          "anyOf": [
            {
              "$ref": "#/definitions/WorkflowSemantic"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "description",
        "id"
      ],
      "type": "object"
    }
  },
  "patternProperties": {
    "^x-": true
  },
  "properties": {
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "entity_ref": {
      "$ref": "#/definitions/EmbeddedWorkflowEntityRef"
    },
    "guidance": {
      "type": [
        "string",
        "null"
      ]
    },
    "intercepts": {
      "additionalProperties": {
        "$ref": "#/definitions/HookCall"
      },
      "type": [
        "object",
        "null"
      ]
    },
    "name": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    },
    "raci": {
      "anyOf": [
        {
          "$ref": "#/definitions/Raci"
        },
        {
          "type": "null"
        }
      ]
    },
    "states": {
      "items": {
        "$ref": "#/definitions/WorkflowStateEntry"
      },
      "minItems": 2,
      "type": "array"
    },
    "steps": {
      "additionalProperties": {
        "$ref": "#/definitions/Step"
      },
      "type": "object"
    }
  },
  "required": [
    "entity_ref",
    "name",
    "purpose",
    "states",
    "steps"
  ],
  "title": "EmbeddedWorkflow",
  "type": "object"
}
