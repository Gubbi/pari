{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EmbeddedWorkflow",
  "description": "A workflow nested inline inside another workflow's step map.\n\nUnlike a [`crate::entity::entities::relay::Relay`] — which points at a separately-defined [`ReusableWorkflow`] — an `EmbeddedWorkflow` is authored in place and identified relative to its parent. This makes it the right choice for one-off nested procedures that do not need to be shared. Its [`WorkflowParent`] is itself recursive so embeddings can nest arbitrarily deep.",
  "type": "object",
  "required": [
    "entity_ref",
    "name",
    "purpose",
    "states",
    "steps"
  ],
  "properties": {
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "entity_ref": {
      "$ref": "#/definitions/EmbeddedWorkflowEntityRef"
    },
    "guidance": {
      "type": [
        "string",
        "null"
      ]
    },
    "intercepts": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": {
        "$ref": "#/definitions/HookCall"
      }
    },
    "name": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    },
    "raci": {
      "anyOf": [
        {
          "$ref": "#/definitions/Raci"
        },
        {
          "type": "null"
        }
      ]
    },
    "states": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/WorkflowStateEntry"
      },
      "minItems": 2
    },
    "steps": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/Step"
      }
    }
  },
  "patternProperties": {
    "^x-": true
  },
  "additionalProperties": false,
  "definitions": {
    "EmbeddedWorkflowEntityRef": {
      "title": "EmbeddedWorkflowEntityRef",
      "type": "object",
      "required": [
        "id",
        "kind",
        "parent"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z][A-Za-z0-9]*$"
        },
        "kind": {
          "type": "string",
          "enum": [
            "EmbeddedWorkflow"
          ]
        },
        "parent": {
          "$ref": "#/definitions/WorkflowParent"
        }
      }
    },
    "HookCall": {
      "description": "Usage-site reference to a hook with optional input bindings.",
      "type": "object",
      "required": [
        "hook"
      ],
      "properties": {
        "hook": {
          "$ref": "#/definitions/HookEntityRef"
        },
        "with": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "HookEntityRef": {
      "title": "HookEntityRef",
      "type": "object",
      "required": [
        "id",
        "kind"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "kind": {
          "type": "string",
          "enum": [
            "Hook"
          ]
        }
      }
    },
    "Raci": {
      "description": "Accountability assignment for workflows and tasks.",
      "type": "object",
      "required": [
        "accountable",
        "responsible"
      ],
      "properties": {
        "accountable": {
          "$ref": "#/definitions/RoleEntityRef"
        },
        "consulted": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/RoleEntityRef"
          }
        },
        "informed": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/RoleEntityRef"
          }
        },
        "responsible": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/RoleEntityRef"
          }
        }
      },
      "additionalProperties": false
    },
    "RelayEntityRef": {
      "title": "RelayEntityRef",
      "type": "object",
      "required": [
        "id",
        "kind",
        "parent"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z][A-Za-z0-9]*$"
        },
        "kind": {
          "type": "string",
          "enum": [
            "Relay"
          ]
        },
        "parent": {
          "$ref": "#/definitions/WorkflowParent"
        }
      }
    },
    "ReusableWorkflowEntityRef": {
      "title": "ReusableWorkflowEntityRef",
      "type": "object",
      "required": [
        "id",
        "kind"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z][A-Za-z0-9]*$"
        },
        "kind": {
          "type": "string",
          "enum": [
            "ReusableWorkflow"
          ]
        }
      }
    },
    "RoleEntityRef": {
      "title": "RoleEntityRef",
      "type": "object",
      "required": [
        "id",
        "kind"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "kind": {
          "type": "string",
          "enum": [
            "Role"
          ]
        }
      }
    },
    "Step": {
      "description": "One position in a workflow's ordered step map.\n\n`Step` is structural glue, not an entity: it has no `EntityRef` and no tracked companion. Each variant carries a reference to the embedded entity that actually runs at that position ([`Task`], [`Relay`], [`EmbeddedWorkflow`]), plus per-step scheduling metadata like `depends_on`. The `Review` variant is the exception — it is resolved inline against roles, not against a separate entity.",
      "oneOf": [
        {
          "type": "object",
          "required": [
            "Task"
          ],
          "properties": {
            "Task": {
              "type": "object",
              "required": [
                "entity_ref"
              ],
              "properties": {
                "depends_on": {
                  "type": [
                    "array",
                    "null"
                  ],
                  "items": {
                    "type": "string"
                  }
                },
                "entity_ref": {
                  "$ref": "#/definitions/TaskEntityRef"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "Relay"
          ],
          "properties": {
            "Relay": {
              "type": "object",
              "required": [
                "entity_ref"
              ],
              "properties": {
                "depends_on": {
                  "type": [
                    "array",
                    "null"
                  ],
                  "items": {
                    "type": "string"
                  }
                },
                "entity_ref": {
                  "$ref": "#/definitions/RelayEntityRef"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "EmbeddedWorkflow"
          ],
          "properties": {
            "EmbeddedWorkflow": {
              "type": "object",
              "required": [
                "entity_ref"
              ],
              "properties": {
                "depends_on": {
                  "type": [
                    "array",
                    "null"
                  ],
                  "items": {
                    "type": "string"
                  }
                },
                "entity_ref": {
                  "$ref": "#/definitions/EmbeddedWorkflowEntityRef"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "Review"
          ],
          "properties": {
            "Review": {
              "type": "object",
              "required": [
                "approver",
                "on_reject"
              ],
              "properties": {
                "approver": {
                  "type": "array",
                  "items": {
                    "$ref": "#/definitions/RoleEntityRef"
                  }
                },
                "on_reject": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "TaskEntityRef": {
      "title": "TaskEntityRef",
      "type": "object",
      "required": [
        "id",
        "kind",
        "parent"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z][A-Za-z0-9]*$"
        },
        "kind": {
          "type": "string",
          "enum": [
            "Task"
          ]
        },
        "parent": {
          "$ref": "#/definitions/WorkflowParent"
        }
      }
    },
    "WorkflowEntityRef": {
      "title": "WorkflowEntityRef",
      "type": "object",
      "required": [
        "id",
        "kind"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z][A-Za-z0-9]*$"
        },
        "kind": {
          "type": "string",
          "enum": [
            "Workflow"
          ]
        }
      }
    },
    "WorkflowParent": {
      "description": "Closed parent hierarchy for entities embedded in the workflow tree.\n\nThe enum recurses through [`EmbeddedWorkflow`] so an embedded workflow can itself be a parent of further tasks, relays, and embeddings — the tree has no fixed depth. Variants are untagged in serde so the `parent` object is just the parent ref, with no wrapper discriminator.",
      "anyOf": [
        {
          "$ref": "#/definitions/WorkflowEntityRef"
        },
        {
          "$ref": "#/definitions/ReusableWorkflowEntityRef"
        },
        {
          "$ref": "#/definitions/EmbeddedWorkflowEntityRef"
        }
      ]
    },
    "WorkflowSemantic": {
      "type": "string",
      "enum": [
        "reviewing",
        "done",
        "blocked",
        "failed"
      ]
    },
    "WorkflowStateEntry": {
      "type": "object",
      "required": [
        "description",
        "id"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "id": {
          "type": "string",
          "pattern": "^[A-Z][A-Za-z0-9]*$"
        },
        "semantic": {
          "anyOf": [
            {
              "$ref": "#/definitions/WorkflowSemantic"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    }
  }
}
