{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Task",
  "type": "object",
  "required": [
    "artifact",
    "criteria",
    "id",
    "instructions",
    "name",
    "purpose",
    "states"
  ],
  "properties": {
    "accountability": {
      "anyOf": [
        {
          "$ref": "#/definitions/Raci"
        },
        {
          "type": "null"
        }
      ]
    },
    "artifact": {
      "$ref": "#/definitions/Artifact"
    },
    "criteria": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "guidance": {
      "type": [
        "string",
        "null"
      ]
    },
    "hooks": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": {
        "$ref": "#/definitions/HookInvocationValue"
      }
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Z][A-Za-z0-9]*$"
    },
    "instructions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "name": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    },
    "states": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/TaskStateEntry"
      },
      "minItems": 2
    }
  },
  "definitions": {
    "Artifact": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "template": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "HookInvocation": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "required": [
            "hook"
          ],
          "properties": {
            "hook": {
              "type": "string"
            },
            "with": {
              "type": [
                "object",
                "null"
              ],
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        }
      ]
    },
    "HookInvocationValue": {
      "anyOf": [
        {
          "$ref": "#/definitions/HookInvocation"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/definitions/HookInvocation"
          }
        }
      ]
    },
    "Raci": {
      "type": "object",
      "required": [
        "accountable",
        "consulted",
        "informed",
        "responsible"
      ],
      "properties": {
        "accountable": {
          "type": "string"
        },
        "consulted": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "informed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "responsible": {
          "type": "string"
        }
      }
    },
    "TaskSemantic": {
      "type": "string",
      "enum": [
        "complete",
        "blocked",
        "failed"
      ]
    },
    "TaskStateEntry": {
      "type": "object",
      "required": [
        "description",
        "id"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "id": {
          "type": "string",
          "pattern": "^[A-Z][A-Za-z0-9]*$"
        },
        "semantic": {
          "anyOf": [
            {
              "$ref": "#/definitions/TaskSemantic"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    }
  }
}
