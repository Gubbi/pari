{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Step",
  "anyOf": [
    {
      "$ref": "#/definitions/WorkStep"
    },
    {
      "$ref": "#/definitions/ReviewStep"
    }
  ],
  "definitions": {
    "ReviewStep": {
      "type": "object",
      "required": [
        "approver",
        "id",
        "on_reject"
      ],
      "properties": {
        "approver": {
          "type": "string"
        },
        "id": {
          "type": "string",
          "pattern": "^[A-Z][A-Za-z0-9]*$"
        },
        "on_reject": {
          "type": "string"
        }
      }
    },
    "WorkStep": {
      "type": "object",
      "required": [
        "id"
      ],
      "properties": {
        "depends_on": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "id": {
          "type": "string",
          "pattern": "^[A-Z][A-Za-z0-9]*$"
        }
      }
    }
  }
}
