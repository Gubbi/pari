{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "definitions": {
    "RoleId": {
      "pattern": "^[a-z][a-z0-9-]*$",
      "type": "string"
    }
  },
  "patternProperties": {
    "^x-": true
  },
  "properties": {
    "id": {
      "$ref": "#/definitions/RoleId"
    },
    "name": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    },
    "traits": {
      "items": {
        "type": "string"
      },
      "type": [
        "array",
        "null"
      ]
    }
  },
  "required": [
    "id",
    "name",
    "purpose"
  ],
  "title": "Role",
  "type": "object"
}
