{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "definitions": {
    "HookId": {
      "pattern": "^[A-Z][A-Za-z0-9]*$",
      "type": "string"
    },
    "HookInput": {
      "properties": {
        "description": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        }
      },
      "required": [
        "description",
        "name",
        "required"
      ],
      "type": "object"
    }
  },
  "patternProperties": {
    "^x-": true
  },
  "properties": {
    "description": {
      "type": "string"
    },
    "id": {
      "$ref": "#/definitions/HookId"
    },
    "inputs": {
      "items": {
        "$ref": "#/definitions/HookInput"
      },
      "type": [
        "array",
        "null"
      ]
    },
    "instructions": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "name": {
      "type": "string"
    }
  },
  "required": [
    "description",
    "id",
    "instructions",
    "name"
  ],
  "title": "Hook",
  "type": "object"
}
