{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "definitions": {
    "HookEntityRef": {
      "properties": {
        "id": {
          "pattern": "^[a-z][a-z0-9-]*$",
          "type": "string"
        },
        "kind": {
          "enum": [
            "Hook"
          ],
          "type": "string"
        }
      },
      "required": [
        "id",
        "kind"
      ],
      "title": "HookEntityRef",
      "type": "object"
    },
    "HookInput": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        }
      },
      "required": [
        "name",
        "required"
      ],
      "type": "object"
    }
  },
  "description": "A reusable instruction unit invoked at workflow or task lifecycle events.\n\nHooks decouple \"what to do when *X* happens\" from the workflow definition itself. A workflow or task references a hook through [`HookCall`](crate::entity::types::HookCall) on a specific trigger (`OnStart`, `OnDone`, …), supplying bindings for the hook's declared inputs. The hook's `instructions` are the contract the executor follows.",
  "patternProperties": {
    "^x-": true
  },
  "properties": {
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "entity_ref": {
      "$ref": "#/definitions/HookEntityRef"
    },
    "inputs": {
      "items": {
        "$ref": "#/definitions/HookInput"
      },
      "type": [
        "array",
        "null"
      ]
    },
    "instructions": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "name": {
      "type": "string"
    }
  },
  "required": [
    "entity_ref",
    "instructions",
    "name"
  ],
  "title": "Hook",
  "type": "object"
}
