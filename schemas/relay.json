{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Relay",
  "type": "object",
  "required": [
    "delegates_to",
    "id",
    "name",
    "purpose",
    "state_map"
  ],
  "properties": {
    "accountability": {
      "anyOf": [
        {
          "$ref": "#/definitions/Raci"
        },
        {
          "type": "null"
        }
      ]
    },
    "briefing": {
      "type": [
        "string",
        "null"
      ]
    },
    "debriefing": {
      "type": [
        "string",
        "null"
      ]
    },
    "delegates_to": {
      "type": "string"
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "guidance": {
      "type": [
        "string",
        "null"
      ]
    },
    "hooks": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": {
        "$ref": "#/definitions/HookInvocationValue"
      }
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Z][A-Za-z0-9]*$"
    },
    "name": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    },
    "state_map": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/StateMapEntry"
      }
    }
  },
  "definitions": {
    "HookInvocation": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "required": [
            "hook"
          ],
          "properties": {
            "hook": {
              "type": "string"
            },
            "with": {
              "type": [
                "object",
                "null"
              ],
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        }
      ]
    },
    "HookInvocationValue": {
      "anyOf": [
        {
          "$ref": "#/definitions/HookInvocation"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/definitions/HookInvocation"
          }
        }
      ]
    },
    "Raci": {
      "type": "object",
      "required": [
        "accountable",
        "consulted",
        "informed",
        "responsible"
      ],
      "properties": {
        "accountable": {
          "type": "string"
        },
        "consulted": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "informed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "responsible": {
          "type": "string"
        }
      }
    },
    "RelayStateSemantic": {
      "type": "string",
      "enum": [
        "complete",
        "blocked",
        "failed"
      ]
    },
    "StateMapEntry": {
      "type": "object",
      "required": [
        "maps_to"
      ],
      "properties": {
        "maps_to": {
          "type": "string"
        },
        "semantic": {
          "anyOf": [
            {
              "$ref": "#/definitions/RelayStateSemantic"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    }
  }
}
