{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "definitions": {
    "EmbeddedWorkflowEntityRef": {
      "properties": {
        "id": {
          "pattern": "^[A-Z][A-Za-z0-9]*$",
          "type": "string"
        },
        "kind": {
          "enum": [
            "EmbeddedWorkflow"
          ],
          "type": "string"
        },
        "parent": {
          "$ref": "#/definitions/WorkflowParent"
        }
      },
      "required": [
        "id",
        "kind",
        "parent"
      ],
      "title": "EmbeddedWorkflowEntityRef",
      "type": "object"
    },
    "HookCall": {
      "additionalProperties": false,
      "description": "Usage-site reference to a hook with optional input bindings.",
      "properties": {
        "hook": {
          "$ref": "#/definitions/HookEntityRef"
        },
        "with": {
          "additionalProperties": {
            "type": "string"
          },
          "type": [
            "object",
            "null"
          ]
        }
      },
      "required": [
        "hook"
      ],
      "type": "object"
    },
    "HookEntityRef": {
      "properties": {
        "id": {
          "pattern": "^[a-z][a-z0-9-]*$",
          "type": "string"
        },
        "kind": {
          "enum": [
            "Hook"
          ],
          "type": "string"
        }
      },
      "required": [
        "id",
        "kind"
      ],
      "title": "HookEntityRef",
      "type": "object"
    },
    "Raci": {
      "additionalProperties": false,
      "description": "Accountability assignment for workflows and tasks.",
      "properties": {
        "accountable": {
          "$ref": "#/definitions/RoleEntityRef"
        },
        "consulted": {
          "items": {
            "$ref": "#/definitions/RoleEntityRef"
          },
          "type": [
            "array",
            "null"
          ]
        },
        "informed": {
          "items": {
            "$ref": "#/definitions/RoleEntityRef"
          },
          "type": [
            "array",
            "null"
          ]
        },
        "responsible": {
          "items": {
            "$ref": "#/definitions/RoleEntityRef"
          },
          "type": "array"
        }
      },
      "required": [
        "accountable",
        "responsible"
      ],
      "type": "object"
    },
    "RelayEntityRef": {
      "properties": {
        "id": {
          "pattern": "^[A-Z][A-Za-z0-9]*$",
          "type": "string"
        },
        "kind": {
          "enum": [
            "Relay"
          ],
          "type": "string"
        },
        "parent": {
          "$ref": "#/definitions/WorkflowParent"
        }
      },
      "required": [
        "id",
        "kind",
        "parent"
      ],
      "title": "RelayEntityRef",
      "type": "object"
    },
    "ReusableWorkflowEntityRef": {
      "properties": {
        "id": {
          "pattern": "^[A-Z][A-Za-z0-9]*$",
          "type": "string"
        },
        "kind": {
          "enum": [
            "ReusableWorkflow"
          ],
          "type": "string"
        }
      },
      "required": [
        "id",
        "kind"
      ],
      "title": "ReusableWorkflowEntityRef",
      "type": "object"
    },
    "RoleEntityRef": {
      "properties": {
        "id": {
          "pattern": "^[a-z][a-z0-9-]*$",
          "type": "string"
        },
        "kind": {
          "enum": [
            "Role"
          ],
          "type": "string"
        }
      },
      "required": [
        "id",
        "kind"
      ],
      "title": "RoleEntityRef",
      "type": "object"
    },
    "StateMapEntry": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "maps_to": {
          "type": "string"
        },
        "semantic": {
          "anyOf": [
            {
              "$ref": "#/definitions/StateMapSemantic"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "maps_to"
      ],
      "type": "object"
    },
    "StateMapSemantic": {
      "enum": [
        "done",
        "blocked",
        "failed"
      ],
      "type": "string"
    },
    "WorkflowEntityRef": {
      "properties": {
        "id": {
          "pattern": "^[A-Z][A-Za-z0-9]*$",
          "type": "string"
        },
        "kind": {
          "enum": [
            "Workflow"
          ],
          "type": "string"
        }
      },
      "required": [
        "id",
        "kind"
      ],
      "title": "WorkflowEntityRef",
      "type": "object"
    },
    "WorkflowParent": {
      "anyOf": [
        {
          "$ref": "#/definitions/WorkflowEntityRef"
        },
        {
          "$ref": "#/definitions/ReusableWorkflowEntityRef"
        },
        {
          "$ref": "#/definitions/EmbeddedWorkflowEntityRef"
        }
      ],
      "description": "Closed parent hierarchy for entities embedded in the workflow tree.\n\nThe enum recurses through [`EmbeddedWorkflow`] so an embedded workflow can itself be a parent of further tasks, relays, and embeddings — the tree has no fixed depth. Variants are untagged in serde so the `parent` object is just the parent ref, with no wrapper discriminator."
    }
  },
  "description": "A handoff step that delegates a portion of a workflow to a [`ReusableWorkflow`].\n\nRelays let a workflow plug in a standard sub-procedure — code review, procurement, onboarding — without inlining or copying it. `delegates_to` names the reusable workflow to run; `state_map` translates the callee's lifecycle states back into the caller's vocabulary so the relay looks like any other step from the outside.",
  "patternProperties": {
    "^x-": true
  },
  "properties": {
    "briefing": {
      "type": [
        "string",
        "null"
      ]
    },
    "debriefing": {
      "type": [
        "string",
        "null"
      ]
    },
    "delegates_to": {
      "$ref": "#/definitions/ReusableWorkflowEntityRef"
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "entity_ref": {
      "$ref": "#/definitions/RelayEntityRef"
    },
    "guidance": {
      "type": [
        "string",
        "null"
      ]
    },
    "intercepts": {
      "additionalProperties": {
        "$ref": "#/definitions/HookCall"
      },
      "type": [
        "object",
        "null"
      ]
    },
    "name": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    },
    "raci": {
      "anyOf": [
        {
          "$ref": "#/definitions/Raci"
        },
        {
          "type": "null"
        }
      ]
    },
    "state_map": {
      "additionalProperties": {
        "$ref": "#/definitions/StateMapEntry"
      },
      "type": "object"
    }
  },
  "required": [
    "delegates_to",
    "entity_ref",
    "name",
    "purpose",
    "state_map"
  ],
  "title": "Relay",
  "type": "object"
}
