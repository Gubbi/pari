{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WorkStep",
  "type": "object",
  "required": [
    "id"
  ],
  "properties": {
    "depends_on": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Z][A-Za-z0-9]*$"
    }
  }
}
