{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Team",
  "type": "object",
  "required": [
    "id",
    "name"
  ],
  "properties": {
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "import": {
      "description": "List of team_ids whose members carry their own roles from the source team.",
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "include": {
      "description": "Map of team_id → role_id: all members of the referenced team are assigned this role.",
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": {
        "type": "string"
      }
    },
    "members": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "#/definitions/TeamMember"
      }
    },
    "name": {
      "type": "string"
    }
  },
  "definitions": {
    "TeamMember": {
      "type": "object",
      "required": [
        "handle",
        "role"
      ],
      "properties": {
        "handle": {
          "type": "string",
          "pattern": "^@[a-z0-9._-]+$"
        },
        "role": {
          "type": "string"
        }
      }
    }
  }
}
