{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "definitions": {
    "TeamId": {
      "pattern": "^[a-z][a-z0-9-]*$",
      "type": "string"
    },
    "TeamMember": {
      "properties": {
        "handle": {
          "pattern": "^@[a-z0-9._-]+$",
          "type": "string"
        },
        "role": {
          "type": "string"
        }
      },
      "required": [
        "handle",
        "role"
      ],
      "type": "object"
    }
  },
  "patternProperties": {
    "^x-": true
  },
  "properties": {
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "id": {
      "$ref": "#/definitions/TeamId"
    },
    "import": {
      "description": "List of team_ids whose members carry their own roles from the source team.",
      "items": {
        "type": "string"
      },
      "type": [
        "array",
        "null"
      ]
    },
    "include": {
      "additionalProperties": {
        "type": "string"
      },
      "description": "Map of team_id → role_id: all members of the referenced team are assigned this role.",
      "type": [
        "object",
        "null"
      ]
    },
    "members": {
      "items": {
        "$ref": "#/definitions/TeamMember"
      },
      "type": [
        "array",
        "null"
      ]
    },
    "name": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "name"
  ],
  "title": "Team",
  "type": "object"
}
