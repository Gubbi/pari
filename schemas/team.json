{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "definitions": {
    "RoleEntityRef": {
      "properties": {
        "id": {
          "pattern": "^[a-z][a-z0-9-]*$",
          "type": "string"
        },
        "kind": {
          "enum": [
            "Role"
          ],
          "type": "string"
        }
      },
      "required": [
        "id",
        "kind"
      ],
      "title": "RoleEntityRef",
      "type": "object"
    },
    "TeamEntityRef": {
      "properties": {
        "id": {
          "pattern": "^[a-z][a-z0-9-]*$",
          "type": "string"
        },
        "kind": {
          "enum": [
            "Team"
          ],
          "type": "string"
        }
      },
      "required": [
        "id",
        "kind"
      ],
      "title": "TeamEntityRef",
      "type": "object"
    },
    "TeamMember": {
      "additionalProperties": false,
      "properties": {
        "handle": {
          "pattern": "^@[a-z0-9._-]+$",
          "type": "string"
        },
        "role": {
          "$ref": "#/definitions/RoleEntityRef"
        }
      },
      "required": [
        "handle",
        "role"
      ],
      "type": "object"
    }
  },
  "description": "A roster binding concrete handles (people or agents) to roles.\n\nWhere [`Role`] describes *what* a position does, `Team` describes *who* fills it. Composition via `include` and `import` lets larger orgs build teams from smaller ones without duplicating membership. Workflow execution resolves a `Role` reference to an actual handle by consulting the active team.",
  "patternProperties": {
    "^x-": true
  },
  "properties": {
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "entity_ref": {
      "$ref": "#/definitions/TeamEntityRef"
    },
    "import": {
      "items": {
        "$ref": "#/definitions/TeamEntityRef"
      },
      "type": [
        "array",
        "null"
      ]
    },
    "include": {
      "items": {
        "items": [
          {
            "$ref": "#/definitions/TeamEntityRef"
          },
          {
            "$ref": "#/definitions/RoleEntityRef"
          }
        ],
        "maxItems": 2,
        "minItems": 2,
        "type": "array"
      },
      "type": [
        "array",
        "null"
      ]
    },
    "members": {
      "items": {
        "$ref": "#/definitions/TeamMember"
      },
      "type": [
        "array",
        "null"
      ]
    },
    "name": {
      "type": "string"
    }
  },
  "required": [
    "entity_ref",
    "name"
  ],
  "title": "Team",
  "type": "object"
}
